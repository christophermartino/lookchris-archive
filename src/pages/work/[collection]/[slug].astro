---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { artworks } from '../../../data/artworks';
import { cloudinaryUrl } from '../../../lib';

export function getStaticPaths() {
  return artworks.map((artwork) => ({ params: { collection: artwork.collection, slug: artwork.slug }, props: { artwork } }));
}
const { artwork } = Astro.props;
const collectionItems = artworks.filter((item) => item.collection === artwork.collection);
const index = collectionItems.findIndex((item) => item.slug === artwork.slug);
const previous = collectionItems[(index - 1 + collectionItems.length) % collectionItems.length];
const next = collectionItems[(index + 1) % collectionItems.length];
---
<BaseLayout title={`${artwork.title} — Christopher Martino`} current="work">
  <article class="detail-layout" data-prev={`/work/${previous.collection}/${previous.slug}`} data-next={`/work/${next.collection}/${next.slug}`}>
    <aside class="detail-meta">
      <p class="counter">{index + 1} / {collectionItems.length}</p>
      <div class="detail-arrows"><a href={`/work/${previous.collection}/${previous.slug}`} aria-label="Previous artwork">←</a><a href={`/work/${next.collection}/${next.slug}`} aria-label="Next artwork">→</a></div>
      <h1>{artwork.title}</h1>
      <p class="detail-year">{artwork.year}</p>
      <dl><dt>Medium</dt><dd>{artwork.medium}</dd><dt>Dimensions</dt><dd>{artwork.dimensions}</dd></dl>
      {artwork.description && <p class="detail-description">{artwork.description}</p>}
      <a class="text-link" href={`/work/${artwork.collection}`}>Back to gallery <span>↙</span></a>
    </aside>
    <figure class="detail-figure">
      <img src={cloudinaryUrl(artwork.publicId, { width: 2200, height: 2200, crop: 'fit' })} alt={artwork.alt} />
    </figure>
  </article>
  <script is:inline>
    const detail = document.querySelector('.detail-layout');
    window.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') location.href = detail.dataset.prev;
      if (event.key === 'ArrowRight') location.href = detail.dataset.next;
      if (event.key === 'Escape') location.href = '/work/paintings';
    });
  </script>
</BaseLayout>
